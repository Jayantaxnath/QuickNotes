{
    "manifest_version": 3,
    "name": "QuickNotes",
    "version": "1.0",
    "description": "Generate concise notes from Coursera transcripts",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://api.groq.com/*"
    ],
    "action": {
        "default_title": "Generate Notes",
        "default_popup": "src/popup.html",
        "default_icon": {
            "16": "assets/icon128.png",
            "32": "assets/icon128.png",
            "48": "assets/icon128.png",
            "128": "assets/icon128.png"
        }
    },
    "icons": {
        "16": "assets/icon128.png",
        "32": "assets/icon128.png",
        "48": "assets/icon128.png",
        "128": "assets/icon128.png"
    }
}